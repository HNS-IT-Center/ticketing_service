// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  Administrator
  Technician
  Sales
  Customer
}

enum Shift {
  morning
  noon
}

enum TicketType {
  service
  warranty_claim
  pc_build
  cleaning
  upgrade
}

// CS intake label — separate from TicketType (internal technical classification)
enum ServiceCategory {
  service
  build_pc
  upgrade
  diagnostic
  on_site
  others
}

enum PickupMethod {
  self_pickup
  courier
}

enum TicketStatus {
  waiting
  on_progress
  done
  ready_for_pickup   // After done: item ready at counter (self-pickup)
  waiting_pickup     // Customer has been notified, not yet picked up
  handed_to_courier  // After done: item handed to courier (courier pickup)
  delivered          // Courier delivered to customer
  completed          // Final state for both pickup paths
  cancelled
  rejected
}

enum DeviceType {
  PC_Office
  PC_Gaming
  Laptop_Office
  Laptop_Gaming
}

enum CustomerType {
  User
  Internet_Cafe
  Company
  Dealer
}

enum TimeLogEvent {
  START
  PAUSE
  RESUME
  DONE
}

enum FileType {
  image
  video
  pdf
}

enum NotificationType {
  message
  status_update
  assigned    // Technician was assigned a ticket
  completed   // Technician completed a ticket (includes points earned)
}

enum CleaningPackage {
  Deep_Clean
  Repaste
}

// ─────────────────────────────────────────────
// STORE LOCATIONS
// ─────────────────────────────────────────────

model StoreLocation {
  id         String  @id @default(cuid())
  name       String  @unique       // e.g. "Nagoya Gateway"
  code       String  @unique       // e.g. "NGW" — used in ticket_code prefix
  address    String?
  is_active  Boolean @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tickets           Ticket[]
  technician_stores TechnicianStoreAssignment[]
}

model TechnicianStoreAssignment {
  id            String        @id @default(cuid())
  technician_id String
  technician    User          @relation(fields: [technician_id], references: [id], onDelete: Cascade)
  store_id      String
  store         StoreLocation @relation(fields: [store_id], references: [id], onDelete: Cascade)
  assigned_at   DateTime      @default(now())

  @@unique([technician_id, store_id])
  @@index([technician_id])
}

// ─────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  phone_number String
  address      String
  role         Role     @default(Customer)
  password     String

  // Technician-specific
  shift     Shift?
  work_days Json?  // e.g. ["Mon","Tue","Wed"]

  // Team leader flag — excluded from leaderboard display but can still work on tickets
  is_team_leader Boolean @default(false)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  tickets_created    Ticket[]              @relation("TicketUser")
  tickets_technician Ticket[]              @relation("TicketTechnician")
  tickets_sales      Ticket[]              @relation("TicketSales")
  messages_sent      TicketMessage[]
  notifications      Notification[]
  status_logs        TicketStatusLog[]
  workload           TechnicianWorkload?
  performance        TechnicianPerformance?
  leaderboards       Leaderboard[]
  store_assignments  TechnicianStoreAssignment[]
  leaves             TechnicianLeave[]
  overridden_shifts  ShiftOverride[]       @relation("OriginalShift")
  overriding_shifts  ShiftOverride[]       @relation("OverrideShift")
  assignment_requests TicketAssignmentRequest[]

  @@index([email])
}

// ─────────────────────────────────────────────
// TICKETS
// ─────────────────────────────────────────────

model Ticket {
  id          String @id @default(cuid())
  ticket_code String @unique

  user_id String?
  user    User?   @relation("TicketUser", fields: [user_id], references: [id])

  ticket_type      TicketType
  service_category ServiceCategory?  // CS intake label (what customer came in for)
  status           TicketStatus @default(waiting)
  device_type      DeviceType

  technician_id String?
  technician    User?   @relation("TicketTechnician", fields: [technician_id], references: [id])

  sales_id String?
  sales    User?   @relation("TicketSales", fields: [sales_id], references: [id])

  // Store location — original intake store (NEVER changes after creation)
  store_location_id String?
  store_location    StoreLocation? @relation(fields: [store_location_id], references: [id])

  notes            String? // Rich text (HTML) — visible to all
  technician_notes String? // Notes from CS to technician — plain text

  is_for_self      Boolean @default(true)  // false = ticket created on behalf of another person
  customer_name    String?                 // Name of the actual recipient (if is_for_self = false)
  customer_phone   String?
  customer_email   String?
  customer_address String?

  customer_type    CustomerType @default(User)

  // CS intake fields
  accessories      String?        // accessories included with device
  device_condition String?        // customer-described physical condition
  is_overnight     Boolean  @default(false)  // true = multi-day service
  is_overnight_check Boolean @default(false)
  checking_fee     Decimal? @db.Decimal(12,2)
  pickup_method    PickupMethod?
  terms_accepted   Boolean  @default(false)

  payment_proof_url   String?
  delivery_proof_url  String?
  progress_proof_url  String?
  revision_proof_url  String?

  // Public access
  public_chat_enabled Boolean @default(false)
  public_share_token  String? @unique    // secure token for /ticket/[token] public page

  // Performance tracking timestamps
  work_started_at   DateTime?  // set when technician moves to on_progress
  work_completed_at DateTime?  // set when technician moves to done

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  attachments      TicketAttachment[]
  messages         TicketMessage[]
  status_logs      TicketStatusLog[]
  time_logs        TicketTimeLog[]
  notifications    Notification[]
  service_detail   TicketServiceDetail?
  warranty_detail  TicketWarrantyDetail?
  cleaning_detail  TicketCleaningDetail?
  upgrade_details  TicketUpgradeDetail[]
  pc_build_detail  TicketPcBuildDetail?
  pc_components    TicketPcBuildComponent[]
  assignment_requests TicketAssignmentRequest[]

  @@index([user_id])
  @@index([technician_id])
  @@index([store_location_id])
  @@index([public_share_token])
}

model TicketAssignmentRequest {
  id            String   @id @default(cuid())
  ticket_id     String
  ticket        Ticket   @relation(fields: [ticket_id], references: [id], onDelete: Cascade)
  technician_id String
  technician    User     @relation(fields: [technician_id], references: [id], onDelete: Cascade)
  status        String   @default("pending") // pending, approved, rejected
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@unique([ticket_id, technician_id])
}

// ─────────────────────────────────────────────
// TICKET DETAIL TABLES
// ─────────────────────────────────────────────

model TicketServiceDetail {
  id        String @id @default(cuid())
  ticket_id String @unique
  ticket    Ticket @relation(fields: [ticket_id], references: [id], onDelete: Cascade)
}

model TicketWarrantyDetail {
  id            String   @id @default(cuid())
  ticket_id     String   @unique
  ticket        Ticket   @relation(fields: [ticket_id], references: [id], onDelete: Cascade)
  purchase_date DateTime
}

model TicketCleaningDetail {
  id              String          @id @default(cuid())
  ticket_id       String          @unique
  ticket          Ticket          @relation(fields: [ticket_id], references: [id], onDelete: Cascade)
  service_package CleaningPackage
}

model Upgrade {
  id     String @id @default(cuid())
  name   String @unique
  points Int    @default(2)

  upgrade_details TicketUpgradeDetail[]
}

model TicketUpgradeDetail {
  id         String  @id @default(cuid())
  ticket_id  String
  ticket     Ticket  @relation(fields: [ticket_id], references: [id], onDelete: Cascade)
  upgrade_id String
  upgrade    Upgrade @relation(fields: [upgrade_id], references: [id])
}

model TicketPcBuildDetail {
  id                 String  @id @default(cuid())
  ticket_id          String  @unique
  ticket             Ticket  @relation(fields: [ticket_id], references: [id], onDelete: Cascade)
  first_build_url    String? // Uploaded by technician upon marking done
  revision_build_url String? // Uploaded by assigned Sales
}

model TicketPcBuildComponent {
  id             String @id @default(cuid())
  ticket_id      String
  ticket         Ticket @relation(fields: [ticket_id], references: [id], onDelete: Cascade)
  component_name String
}

// ─────────────────────────────────────────────
// ATTACHMENTS & MESSAGES
// ─────────────────────────────────────────────

model TicketAttachment {
  id         String   @id @default(cuid())
  ticket_id  String
  ticket     Ticket   @relation(fields: [ticket_id], references: [id], onDelete: Cascade)
  file_url   String
  file_type  FileType
  created_at DateTime @default(now())
}

model TicketMessage {
  id        String @id @default(cuid())
  ticket_id String
  ticket    Ticket @relation(fields: [ticket_id], references: [id], onDelete: Cascade)

  sender_id   String?       // null = anonymous public message
  sender      User?   @relation(fields: [sender_id], references: [id])
  sender_name String?       // for anonymous senders

  message  String
  is_read  Boolean @default(false)

  created_at DateTime @default(now())

  @@index([ticket_id])
}

// ─────────────────────────────────────────────
// STATUS LOGS
// ─────────────────────────────────────────────

model TicketStatusLog {
  id         String       @id @default(cuid())
  ticket_id  String
  ticket     Ticket       @relation(fields: [ticket_id], references: [id], onDelete: Cascade)
  old_status TicketStatus?
  new_status TicketStatus
  reason     String?
  changed_by String
  changer    User         @relation(fields: [changed_by], references: [id])
  created_at DateTime     @default(now())
}

// ─────────────────────────────────────────────
// WORKLOAD & PERFORMANCE
// ─────────────────────────────────────────────

model TechnicianWorkload {
  id             String   @id @default(cuid())
  technician_id  String   @unique
  technician     User     @relation(fields: [technician_id], references: [id])
  current_points Int      @default(0)
  max_points     Int      @default(7)
  updated_at     DateTime @updatedAt
}

model TechnicianPerformance {
  id            String @id @default(cuid())
  technician_id String @unique
  technician    User   @relation(fields: [technician_id], references: [id])

  tickets_handled        Int @default(0)
  success_count          Int @default(0)
  failed_count           Int @default(0)
  total_points_completed Int @default(0)

  updated_at DateTime @updatedAt
}

model Leaderboard {
  id            String @id @default(cuid())
  technician_id String
  technician    User   @relation(fields: [technician_id], references: [id])

  month Int
  year  Int

  total_points    Int
  tickets_handled Int

  created_at DateTime @default(now())
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────

model Notification {
  id        String @id @default(cuid())
  user_id   String
  user      User   @relation(fields: [user_id], references: [id])
  ticket_id String
  ticket    Ticket @relation(fields: [ticket_id], references: [id], onDelete: Cascade)

  type         NotificationType
  reference_id String? // e.g. message_id or status_log_id
  message      String? // Optional human-readable detail (e.g. points earned message)

  is_read Boolean @default(false)

  created_at DateTime @default(now())

  @@index([user_id])
}

// ─────────────────────────────────────────────
// TIME LOGGING & SCHEDULING (PHASE 3)
// ─────────────────────────────────────────────

model TicketTimeLog {
  id         String       @id @default(cuid())
  ticket_id  String
  ticket     Ticket       @relation(fields: [ticket_id], references: [id], onDelete: Cascade)
  event      TimeLogEvent
  reason     String?
  created_at DateTime     @default(now())

  @@index([ticket_id])
}

model TechnicianLeave {
  id            String   @id @default(cuid())
  technician_id String
  technician    User     @relation(fields: [technician_id], references: [id], onDelete: Cascade)
  date          DateTime @db.Date
  reason        String?
  is_off_day    Boolean  @default(false)
  created_at    DateTime @default(now())

  @@unique([technician_id, date])
}

model ShiftOverride {
  id               String   @id @default(cuid())
  original_tech_id String
  override_tech_id String
  original_tech    User     @relation("OriginalShift", fields: [original_tech_id], references: [id], onDelete: Cascade)
  override_tech    User     @relation("OverrideShift", fields: [override_tech_id], references: [id], onDelete: Cascade)
  date             DateTime @db.Date
  shift            Shift
  created_at       DateTime @default(now())

  @@unique([original_tech_id, date])
}
