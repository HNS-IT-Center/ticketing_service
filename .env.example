# Database connection string (Supabase Session Pooler - port 5432 or 6543)
# IMPORTANT: Must append ?sslmode=no-verify if using Supabase Pooler
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[DB_PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres?sslmode=no-verify"

# Supabase Project settings
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Authentication Session Secret (Generate a random 32+ char string)
SESSION_SECRET="generate-a-random-32+-char-string-here"

# Application URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
